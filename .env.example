# Local bot runtime configuration.
# Fill these in, then restart the bot with `npm start`.

MATTERMOST_URL=http://localhost:8065
MATTERMOST_BOT_TOKEN=
MATTERMOST_BOT_USERNAME=acorn-ops-bot

ACORNOPS_API_BASE_URL=http://localhost:8081
EXTERNAL_INTEGRATION_SERVICE_TOKEN=

# For HTTP server, to listen for buttons and webhooks
BOT_HTTP_HOST=0.0.0.0
BOT_HTTP_PORT=8077
BOT_PUBLIC_BASE_URL=http://localhost:8077
# BOT_DATABASE_URL=
MATTERMOST_ACTION_SECRET=local-action-secret
