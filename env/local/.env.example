# Local-only Mattermost bot stack. `task local-up` copies this file to
# env/local/.env.local when that ignored file does not yet exist.

# The local image is built from Mattermost's checksum-verified official Team
# Edition release archive for Docker's native architecture (amd64 or arm64).
MATTERMOST_VERSION=11.7.0
MATTERMOST_PORT=8065
MATTERMOST_SITE_URL=http://localhost:8065

MATTERMOST_POSTGRES_DB=mattermost
MATTERMOST_POSTGRES_USER=mmuser
MATTERMOST_POSTGRES_PASSWORD=mmuser_password_local_only

# Idempotent local seed. Override at invocation time with:
# task local-up SEED_MATTERMOST_DATA=false
SEED_MATTERMOST_DATA=true
LOCAL_MATTERMOST_USERNAME=dev
LOCAL_MATTERMOST_USER_EMAIL=dev@acornops.local
LOCAL_MATTERMOST_USER_PASSWORD=devpassword
LOCAL_MATTERMOST_TEAM=csit-lab
LOCAL_MATTERMOST_TEAM_DISPLAY_NAME='CSIT Lab'
LOCAL_MATTERMOST_CHANNEL=chatops-lab
LOCAL_MATTERMOST_CHANNEL_DISPLAY_NAME='ChatOps Lab'
LOCAL_MATTERMOST_BOT_USERNAME=acorn-ops-bot
LOCAL_MATTERMOST_BOT_EMAIL=acorn-ops-bot@acornops.local
LOCAL_MATTERMOST_BOT_INITIAL_PASSWORD=local-bot-password

# Container-to-host addresses used by the bot. The AcornOps full stack remains
# owned by acornops-deployment and should be started separately with task local-up.
MATTERMOST_URL=http://host.docker.internal:8065
MATTERMOST_BOT_USERNAME=acorn-ops-bot
ACORNOPS_API_BASE_URL=http://host.docker.internal:8081
ACORNOPS_CONSOLE_BASE_URL=http://console.acornops.localhost:8088
EXTERNAL_INTEGRATION_SERVICE_TOKEN=dev_external_integration_client_token

BOT_POSTGRES_DB=acornops_bot
BOT_POSTGRES_USER=acornops_bot
BOT_POSTGRES_PASSWORD=acornops_bot
BOT_HTTP_HOST=0.0.0.0
BOT_HTTP_PORT=8077
BOT_PUBLIC_BASE_URL=http://host.docker.internal:8077
BOT_HOST_BASE_URL=http://localhost:8077
MATTERMOST_ACTION_SECRET=local-action-secret-change-outside-development
BOT_ALERT_TIME_ZONE=Asia/Singapore

CHAT_RUN_POLL_ATTEMPTS=15
CHAT_RUN_POLL_INTERVAL_MS=1000
RUN_STREAM_RECONNECT_ATTEMPTS=3
RUN_STREAM_RECONNECT_DELAY_MS=1000
RUN_STREAM_FALLBACK_POLL_INTERVAL_MS=3000
RUN_STREAM_FALLBACK_POLL_MAX_MS=180000
WORKFLOW_FOLLOW_RETRY_DELAY_MS=3000
