# Demo-only public Mattermost and AcornOps endpoints.
MATTERMOST_VERSION=11.7.0
MATTERMOST_SITE_URL=https://mattermost.demo.acornops.dev
BOT_PUBLIC_BASE_URL=https://mattermost-bot.demo.acornops.dev
ACORNOPS_API_BASE_URL=https://api.demo.acornops.dev
ACORNOPS_CONSOLE_BASE_URL=https://console.demo.acornops.dev

# The deploy script replaces this with Docker's private bridge gateway so the
# k3s Traefik pod can reach the backends without publishing high ports on the
# VM's public interface.
DEMO_BIND_ADDRESS=127.0.0.1
MATTERMOST_PORT=8065
BOT_HTTP_PORT=8077

MATTERMOST_POSTGRES_DB=mattermost
MATTERMOST_POSTGRES_USER=mmuser
MATTERMOST_POSTGRES_PASSWORD=replace-with-url-safe-random-password

BOT_POSTGRES_DB=acornops_bot
BOT_POSTGRES_USER=acornops_bot
BOT_POSTGRES_PASSWORD=replace-with-url-safe-random-password

DEMO_MATTERMOST_ADMIN_USERNAME=demo-admin
DEMO_MATTERMOST_ADMIN_EMAIL=demo-admin@acornops.dev
DEMO_MATTERMOST_ADMIN_PASSWORD=replace-with-demo-admin-password
DEMO_MATTERMOST_USERNAME=demo
DEMO_MATTERMOST_USER_EMAIL=demo@acornops.dev
DEMO_MATTERMOST_USER_PASSWORD=replace-with-demo-user-password
DEMO_MATTERMOST_TEAM=acornops-demo
DEMO_MATTERMOST_TEAM_DISPLAY_NAME='AcornOps Demo'
DEMO_MATTERMOST_CHANNEL=chatops
DEMO_MATTERMOST_CHANNEL_DISPLAY_NAME='ChatOps'
MATTERMOST_BOT_USERNAME=acorn-ops-bot
DEMO_MATTERMOST_BOT_EMAIL=acorn-ops-bot@acornops.dev
DEMO_MATTERMOST_BOT_INITIAL_PASSWORD=replace-with-bot-bootstrap-password

EXTERNAL_INTEGRATION_SERVICE_TOKEN=replace-with-external-integration-token
MATTERMOST_ACTION_SECRET=replace-with-random-action-signing-secret
BOT_ALERT_TIME_ZONE=Asia/Singapore

BOT_IMAGE_TAG=demo
BOT_IMAGE_REVISION=local
